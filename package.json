{
	"name": "alignargs",
	"displayName": "Align Args",
	"description": "Align arguments in single line function calls",
	"icon": "images/alignargsIcon.png",
	"version": "1.0.1",
	"engines": {
		"vscode": "^1.110.0"
	},
	"categories": [
		"Formatters"
	],
	"activationEvents": [
		"onCommand:alignargs.alignargs"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "alignargs.alignargs",
				"title": "Align Args"
			}
		],
		"menus": {
			"editor/context": [
				{
					"command": "alignargs.alignargs",
					"when": "editorHasSelection"
				}
			]
		},
		"configuration": {
			"title": "Align Args",
			"properties": {
				"alignargs.alignDecimal": {
					"type": "string",
					"default": "right",
					"description": "Align type of decimal values",
					"enum": [
						"left",
						"center",
						"right"
					]
				},
				"alignargs.alignNonDecimal": {
					"type": "string",
					"default": "left",
					"description": "Align type of non-decimal values",
					"enum": [
						"left",
						"center",
						"right"
					]
				},
				"alignargs.formatHex": {
					"type": "boolean",
					"default": true,
					"description": "ex) 0XabU -> 0xABu"
				},
				"alignargs.trimTrail": {
					"type": "boolean",
					"default": true,
					"description": "Trim leading and trailing whitespace inside each argument before aligning"
				},
				"alignargs.padType": {
					"type": "string",
					"default": "space",
					"enum": [
						"space",
						"tab(experimental)"
					],
					"description": "Pad with space(recommended) or tab(width 4. overrides left/center/right align)"
				},
				"alignargs.replaceArg": {
					"type": "object",
					"description": "Replace argument 'Key' -> 'Value'",
					"scope": "resource",
					"default": {
						"t": "TRUE",
						"T": "TRUE",
						"f": "FALSE",
						"F": "FALSE"
					},
					"additionalProperties": {
						"type": "string"
					}
				}
			}
		}
	},
	"scripts": {
		"precompile": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint src --ext ts",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.5.0",
		"@types/vscode": "^1.110.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"@vscode/test-electron": "^2.5.2",
		"eslint": "^10.1.0",
		"glob": "^13.0.6",
		"globals": "^17.4.0",
		"mocha": "^11.7.5",
		"typescript": "^5.9.3"
	},
	"publisher": "yongsooim",
	"repository": "https://github.com/YongsooIm/vscode-alignargs"
}
